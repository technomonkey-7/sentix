# Google Gemini API Settings
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Settings (configurable to use latest models)
# e.g., gemini-3.1-flash-lite, gemini-3.5-flash, gemini-2.5-pro, etc.
SUMMARIZER_MODEL=gemini-3.1-flash-lite
SENTIMENT_MODEL=gemini-3.5-flash

# Trading Settings
SELECTED_ASSETS=BTC/USDT,ETH/USDT,SOL/USDT
INITIAL_USD_BALANCE=10000.0
SIMULATION_INTERVAL_SECONDS=60
MIN_AI_SENTIMENT_THRESHOLD=3

# Dashboard Access Password (uncomment and set to restrict access on public servers)
# ACCESS_PASSWORD=your_secure_password_here

# CCXT Exchange name (e.g., binance, bybit, okx, gate, kraken)
# Use bybit or okx if your server is in a region blocked by Binance (e.g. US)
# EXCHANGE_NAME=bybit

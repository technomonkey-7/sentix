# ============ Google Gemini API (AI sentiment — optional) ============
GEMINI_API_KEY=your_gemini_api_key_here
# For key rotation create gemini_keys.txt (one key per line) instead.
SUMMARIZER_MODEL=gemini-3.1-flash-lite
SENTIMENT_MODEL=gemini-3.5-flash

# ============ Watchlist ============
# Plain yfinance tickers, comma separated. Crypto uses the -USD suffix and trades 24/7.
# Diversified default: tech + financials + healthcare + energy + staples + industrials + gold.
SELECTED_ASSETS=AAPL,MSFT,NVDA,AMZN,GOOGL,META,JPM,V,LLY,JNJ,XOM,PG,WMT,CAT,GLD,SPY

# ============ Engine ============
INITIAL_USD_BALANCE=10000.0
SIMULATION_INTERVAL_SECONDS=300
GUARDIAN_INTERVAL_SECONDS=60
LIVE_MODE=false

# ============ Risk management (v2: true risk-based sizing) ============
# % of NAV lost if the initial stop is hit (position size is derived from this)
RISK_PER_TRADE_PCT=1.0
# Stop distance = ATR_MULT_SL x ATR14(1h), clamped to [3%, 8%] of entry
# (defaults tuned on 12/22-month real-data backtests)
ATR_MULT_SL=4.5
# Take profit = RR_RATIO x risk distance
RR_RATIO=1.5
TRAIL_ATR_MULT=2.5
# Entries below this confluence score (0-100) are skipped
MIN_CONFLUENCE_SCORE=65
MAX_OPEN_POSITIONS=5
# Max concurrent positions in the same sector (tech, financials, energy, ...)
MAX_PER_SECTOR=2
MAX_POSITION_PCT=20.0
MAX_TOTAL_EXPOSURE_PCT=80.0
DAILY_LOSS_LIMIT_PCT=3.0
COOLDOWN_HOURS=24
FEE_PCT=0.0005
SLIPPAGE_PCT=0.0005
MARKET_FILTER_ENABLED=true
AI_ENABLED=true
MIN_AI_SENTIMENT_THRESHOLD=3

# ============ Dashboard ============
# Uncomment to password-protect the Streamlit dashboard on public servers
# ACCESS_PASSWORD=your_secure_password_here

# ============ Telegram integration ============
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============ Optional: VPN (Gluetun) ============
# VPN_SERVICE_PROVIDER=protonvpn
# VPN_TYPE=openvpn
# VPN_USER=your_openvpn_username_here
# VPN_PASSWORD=your_openvpn_password_here
# VPN_COUNTRIES=Netherlands
# VPN_FREE_ONLY=on

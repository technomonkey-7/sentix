# Google Gemini API Settings
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Settings (configurable to use latest models)
# e.g., gemini-3.1-flash-lite, gemini-3.5-flash, gemini-2.5-pro, etc.
SUMMARIZER_MODEL=gemini-3.1-flash-lite
SENTIMENT_MODEL=gemini-3.5-flash

# Trading Settings
# Transitioned from crypto to traditional Stock & ETF watchlist
SELECTED_ASSETS=AAPL/USD,MSFT/USD,NVDA/USD,AMD/USD,ARM/USD,TSM/USD,AVGO/USD,ASML/USD,AMZN/USD,GOOGL/USD,META/USD,TSLA/USD,QQQ/USD,SPY/USD
INITIAL_USD_BALANCE=10000.0
SIMULATION_INTERVAL_SECONDS=300
MIN_AI_SENTIMENT_THRESHOLD=3
LIVE_MODE=false

# Risk Management
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=5.0
TRAILING_STOP_LOSS_PCT=2.0
RISK_PERCENTAGE=2.0
FEE_PCT=0.0005

# Dashboard Access Password (uncomment and set to restrict access on public servers)
# ACCESS_PASSWORD=your_secure_password_here

# CCXT Exchange name (e.g., binance, bybit, okx, gate, kraken)
# Use bybit or okx if your server is in a region blocked by Binance (e.g. US)
# EXCHANGE_NAME=bybit

# Telegram Integration Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: VPN Credentials (only needed if vpn_check_enabled is set to true in SQLite config)
# VPN_SERVICE_PROVIDER=protonvpn
# VPN_TYPE=openvpn
# VPN_USER=your_openvpn_username_here
# VPN_PASSWORD=your_openvpn_password_here
# VPN_COUNTRIES=Netherlands
# VPN_FREE_ONLY=on
